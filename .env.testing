APP_NAME=CVactive
APP_ENV=testing
APP_KEY=base64:Lsz8R5PMqqs8yKotHEX4f35SsVv0stYtRlmJhPrd7E8=
APP_DEBUG=false
APP_URL=http://127.0.0.1:8000

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# CI test dùng sqlite in-memory để tránh phụ thuộc MySQL
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

# Session test
SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=array

MAIL_MAILER=array
MAIL_FROM_ADDRESS="test@cvactive.com"
MAIL_FROM_NAME="CVactive Test"

# Throttle test mode
SECURITY_HEADERS_ENABLED=true